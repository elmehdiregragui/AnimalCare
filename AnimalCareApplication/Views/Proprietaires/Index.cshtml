@model IEnumerable<AnimalCareApplication.Models.Proprietaire>

@{
    ViewData["Title"] = "Gestion des Propriétaires";
}

<div class="lux-container">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold">Gestion des Propriétaires</h2>
        <a asp-action="Create">Créer un nouveau propriétaire</a>

    </div>

    <div class="table-responsive lux-table">
        <table class="table table-hover align-middle">
            <thead>
                <tr>
                    <th>Nom</th>
                    <th>Prénom</th>
                    <th>Adresse</th>
                    <th>Téléphone</th>
                    <th>Email</th>
                    <th class="text-center">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="fw-semibold">@item.Nom</td>
                        <td>@item.Prenom</td>
                        <td>@item.Adresse</td>
                        <td>@item.Telephone</td>
                        <td>@item.Email</td>
                        <td class="text-center">
                            <a asp-action="Edit" asp-route-id="@item.IdProprietaire" class="btn btn-sm btn-primary">Modifier</a>
                            <a asp-action="Details" asp-route-id="@item.IdProprietaire" class="btn btn-sm btn-info text-white">Détails</a>
                            <a asp-action="Delete" asp-route-id="@item.IdProprietaire" class="btn btn-sm btn-danger">Supprimer</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

</div>
