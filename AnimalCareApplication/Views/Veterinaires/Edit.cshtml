@model AnimalCareApplication.Models.Veterinaire

<h2>Modifier le vétérinaire</h2>

<form asp-action="Edit" method="post">
    <input type="hidden" name="id" value="@Model.IdVeterinaire" />

    <div class="form-group">
        <label>Vétérinaire</label>
        <input class="form-control"
               value="Vétérinaire #@Model.IdVeterinaire"
               disabled />
    </div>

    <div class="form-group">
        <label>Spécialité</label>
        <input name="Specialite" value="@Model.Specialite" class="form-control" />
    </div>

    <br />

    <button type="submit" class="btn btn-primary">Enregistrer</button>
    <a asp-action="Index" class="btn btn-secondary">Retour</a>
</form>

