@model IEnumerable<AnimalCareApplication.Models.RendezVou>

<table class="table table-hover align-middle">
    <thead>
        <tr>
            <th>Date</th>
            <th>Heure</th>
            <th>Statut</th>
            <th>État</th>
            <th>Animal</th>
            <th>Vétérinaire</th>
            <th class="text-center">Actions</th>
        </tr>
    </thead>

    <tbody>
        @foreach (var item in Model)
        {
            var nomVet = item.IdVeterinaireNavigation != null && item.IdVeterinaireNavigation.IdUtilisateurNavigation != null
            ? item.IdVeterinaireNavigation.IdUtilisateurNavigation.Prenom + " " + item.IdVeterinaireNavigation.IdUtilisateurNavigation.Nom
            : "Non défini";

            <tr>
                <td>@item.DateRv.ToString("dd/MM/yyyy")</td>
                <td>@item.Heure.ToString(@"hh\:mm")</td>

                <td>@item.Statut</td>
                <td>@item.Etat</td>

                <td>@(item.IdAnimalNavigation?.Nom ?? "Animal inconnu")</td>
                <td>@nomVet</td>

                <td class="text-center">
                    <a asp-controller="Client"
                       asp-action="ModifierRendezVous"
                       asp-route-id="@item.IdRendezVous">
                        Modifier
                    </a>

                    <a asp-controller="Client"
                       asp-action="SupprimerRendezVous"
                       asp-route-id="@item.IdRendezVous">
                        Supprimer
                    </a>
                </td>
            </tr>
        }
    </tbody>
</table>