@model AnimalCareApplication.Models.ClientRendezVousViewModel

@{
    ViewData["Title"] = "Modifier rendez-vous";
}

<div class="form-page">
    <div class="form-card">

        <h2>Modifier un rendez-vous</h2>

        <form asp-action="ModifierRendezVous" method="post">
            @Html.AntiForgeryToken()

            <input type="hidden" asp-for="IdRendezVous" />

            <div class="form-group mb-3">
                <label>Date</label>
                <input asp-for="DateRv" type="date" class="form-control" />
            </div>

            <div class="form-group mb-3">
                <label>Heure</label>
                <input asp-for="Heure" type="time" class="form-control" />
            </div>

            <div class="form-group mb-3">
                <label>Animal</label>
                <select asp-for="IdAnimal" asp-items="Model.Animaux" class="form-control"></select>
            </div>

            <div class="form-group mb-4">
                <label>Vétérinaire</label>
                <select asp-for="IdVeterinaire" asp-items="Model.Veterinaires" class="form-control"></select>
            </div>

            <div class="form-actions">
                <button type="submit" class="btn-main">Enregistrer</button>
                <a asp-action="MesRendezVous" class="btn-cancel">Annuler</a>
            </div>
        </form>

    </div>
</div>
