@using Microsoft.AspNetCore.Http

<!DOCTYPE html>
<html lang="en">
<head>
    ...
</head>
<link rel="stylesheet" href="~/css/site.css" />
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-3">
            <div class="container-fluid">
                <a class="navbar-brand" asp-controller="Home" asp-action="Index">AnimalCare</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse"
                        aria-controls="navbarSupportedContent" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    @{
                        var role = (Context.Session.GetString("UserRole") ?? "").Trim();
                    }

                    <ul class="navbar-nav flex-grow-1">
                        @if (!string.IsNullOrEmpty(role))
                        {
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-controller="Home" asp-action="Index">Accueil</a>
                            </li>

                            @if (role == "Administrateur")
                            {
                                <li class="nav-item">
                                    <a class="nav-link text-dark" asp-controller="Proprietaires" asp-action="Index">Propriétaires</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link text-dark" asp-controller="Animals" asp-action="Index">Animaux</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link text-dark" asp-controller="RendezVous" asp-action="Index">Rendez-vous</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link text-dark" asp-controller="Veterinaires" asp-action="Index">Vétérinaires</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link text-dark" asp-controller="Horaires" asp-action="Index">Horaires</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link text-dark" asp-controller="Historiques" asp-action="Index">Historique médical</a>
                                </li>
                            }
                           
                            else if (role == "Secrétaire")
                            {
                                <li class="nav-item">
                                    <a class="nav-link text-dark" asp-controller="Proprietaires" asp-action="Index">Propriétaires</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link text-dark" asp-controller="Animals" asp-action="Index">Animaux</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link text-dark" asp-controller="RendezVous" asp-action="Index">Rendez-vous</a>
                                </li>
                            }
                          
                            else if (role == "Vétérinaire")
                            {
                                <li class="nav-item">
                                    <a class="nav-link text-dark" asp-controller="Animals" asp-action="Index">Animaux</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link text-dark" asp-controller="RendezVous" asp-action="Index">Rendez-vous</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link text-dark" asp-controller="Horaires" asp-action="Index">Horaires</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link text-dark" asp-controller="Historiques" asp-action="Index">Historique médical</a>
                                </li>
                            }
                            @* CLIENT *@
                            else if (role == "Client")
                            {
                                <li class="nav-item">
                                    <a class="nav-link text-dark"
                                       asp-controller="Client"
                                       asp-action="PrendreRendezVous">
                                        Prendre rendez-vous
                                    </a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link text-dark" asp-controller="Client" asp-action="MesRendezVous">
                                        Mes rendez-vous
                                    </a>
                                </li>

                            }

                           
                            <li class="nav-item">
                                <a class="nav-link text-danger" asp-controller="Auth" asp-action="Logout">Déconnexion</a>
                            </li>
                        }
                        else
                        {
                           
                            <li class="nav-item nav-btn">
                                <a class="nav-link btn-nav" asp-controller="Auth" asp-action="Login">
                                    Connexion
                                </a>
                            </li>

                            <li class="nav-item nav-btn">
                                <a class="nav-link btn-nav-outline" asp-controller="Auth" asp-action="Register">
                                    Créer un compte
                                </a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
    <footer>
        <p>© 2025 AnimalCare – Clinique Vétérinaire | Tous droits réservés</p>
    </footer>

</body>
</html>
