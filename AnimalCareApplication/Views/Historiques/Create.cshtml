@model AnimalCareApplication.Models.Historique

@{
    ViewData["Title"] = "Ajouter un soin (Historique)";
}

<div class="form-page">
    <div class="form-card">

        <h2>Ajouter un soin (Historique)</h2>

        <form asp-action="Create">

            <div class="form-group mb-3">
                <label>Date du soin</label>
                <input asp-for="DateSoin" type="datetime-local" class="form-control" />
            </div>

            <div class="form-group mb-3">
                <label>Description</label>
                <textarea asp-for="Description" class="form-control" rows="3"></textarea>
            </div>

            <div class="form-group mb-4">
                <label>Animal</label>
                <select asp-for="IdAnimal" asp-items="ViewBag.IdAnimal" class="form-control"></select>
            </div>

            <div class="form-actions">
                <button type="submit" class="btn-main">Créer</button>
                <a asp-action="Index" class="btn-cancel">Retour</a>
            </div>

        </form>

    </div>
</div>
