@model AnimalCareApplication.Models.Animal

<div class="form-page">
    <div class="form-card">

        <h2>Ajouter un animal</h2>

        <form asp-action="Create">

            <div class="form-group mb-3">
                <label>Nom</label>
                <input asp-for="Nom" class="form-control" />
            </div>

            <div class="form-group mb-3">
                <label>Espèce</label>
                <input asp-for="Espece" class="form-control" />
            </div>
            
            <div class="form-group mb-3">
                <label>Race</label>
                <input asp-for="Race" class="form-control" />
            </div>

            <div class="form-group mb-3">
                <label>Âge</label>
                <input asp-for="Age" class="form-control" />
            </div>

            <div class="form-group mb-4">
                <label>Propriétaire</label>
                <select asp-for="IdProprietaire" asp-items="ViewBag.IdProprietaire" class="form-control"></select>
            </div>

            <div class="form-actions">
                <button type="submit" class="btn-main">Ajouter</button>
                <a asp-action="Index" class="btn-cancel">Retour</a>
            </div>

        </form>

    </div>
</div>
