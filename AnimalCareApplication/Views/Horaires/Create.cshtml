@model AnimalCareApplication.Models.Horaire

@{
    ViewData["Title"] = "Créer un horaire";
}

<div class="form-page">
    <div class="form-card">

        <h2>Créer un horaire</h2>

        <form asp-action="Create">

            <div class="form-group mb-3">
                <label>Jour</label>
                <input asp-for="Jour" class="form-control" />
            </div>

            <div class="form-group mb-3">
                <label>Heure de début</label>
                <input asp-for="HeureDebut" class="form-control" />
            </div>

            <div class="form-group mb-3">
                <label>Heure de fin</label>
                <input asp-for="HeureFin" class="form-control" />
            </div>

            <div class="form-group mb-4">
                <label>Vétérinaire</label>
                <select asp-for="IdVeterinaire" asp-items="ViewBag.IdVeterinaire" class="form-control"></select>
            </div>

            <div class="form-actions">
                <button type="submit" class="btn-main">Créer</button>
                <a asp-action="Index" class="btn-cancel">Retour à la liste</a>
            </div>

        </form>

    </div>
</div>
