@model AnimalCareApplication.Models.Horaire

@{
    ViewData["Title"] = "Détails de l'horaire";

    var nomVet = Model.IdVeterinaireNavigation != null && Model.IdVeterinaireNavigation.IdUtilisateurNavigation != null
        ? Model.IdVeterinaireNavigation.IdUtilisateurNavigation.Prenom + " " + Model.IdVeterinaireNavigation.IdUtilisateurNavigation.Nom
        : "Non défini";
}

<h1>Détails</h1>

<div>
    <h4>Horaire</h4>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">Jour</dt>
        <dd class="col-sm-10">@Model.Jour</dd>

        <dt class="col-sm-2">Heure début</dt>
        <dd class="col-sm-10">@Model.HeureDebut.ToString(@"hh\:mm")</dd>

        <dt class="col-sm-2">Heure fin</dt>
        <dd class="col-sm-10">@Model.HeureFin.ToString(@"hh\:mm")</dd>

        <dt class="col-sm-2">Vétérinaire</dt>
        <dd class="col-sm-10">@nomVet</dd>
    </dl>
</div>

<div>
    <a asp-action="Edit" asp-route-id="@Model?.IdHoraire">Modifier</a> |
    <a asp-action="Index">Retour à la liste</a>
</div>