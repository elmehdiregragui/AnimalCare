@model AnimalCareApplication.Models.Horaire

@{
    ViewData["Title"] = "Modifier un horaire";
    string role = ViewBag.Role as string ?? "";
    bool isVet = role == "Vétérinaire";
}

<h1>Modifier un horaire</h1>

<form asp-action="Edit" method="post">
    <input type="hidden" asp-for="IdHoraire" />

    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    <div class="form-group">
        <label asp-for="Jour" class="control-label"></label>
        <input asp-for="Jour" class="form-control" />
        <span asp-validation-for="Jour" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="HeureDebut" class="control-label"></label>
        <input asp-for="HeureDebut" class="form-control" />
        <span asp-validation-for="HeureDebut" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="HeureFin" class="control-label"></label>
        <input asp-for="HeureFin" class="form-control" />
        <span asp-validation-for="HeureFin" class="text-danger"></span>
    </div>

    @if (isVet)
    {
        <div class="form-group">
            <label class="control-label">Vétérinaire</label>
            <input type="text" class="form-control" value="@ViewBag.VetName" readonly />
            <input type="hidden" name="IdVeterinaire" value="@ViewBag.VetId" />
        </div>
    }
    else
    {
        <div class="form-group">
            <label asp-for="IdVeterinaire" class="control-label"></label>
            <select asp-for="IdVeterinaire" class="form-control" asp-items="ViewBag.IdVeterinaire"></select>
            <span asp-validation-for="IdVeterinaire" class="text-danger"></span>
        </div>
    }

    <button type="submit" class="btn btn-primary">Enregistrer</button>
    <a asp-action="Index" class="btn btn-secondary">Retour à la liste</a>
</form>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
