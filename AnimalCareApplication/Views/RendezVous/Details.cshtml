@model AnimalCareApplication.Models.RendezVou

@{
    ViewData["Title"] = "Détails du rendez-vous";

    var nomVet = Model.IdVeterinaireNavigation != null && Model.IdVeterinaireNavigation.IdUtilisateurNavigation != null
        ? Model.IdVeterinaireNavigation.IdUtilisateurNavigation.Prenom + " " + Model.IdVeterinaireNavigation.IdUtilisateurNavigation.Nom
        : "Non défini";

    var nomProprietaire = Model.IdAnimalNavigation != null && Model.IdAnimalNavigation.IdProprietaireNavigation != null
        ? Model.IdAnimalNavigation.IdProprietaireNavigation.Prenom + " " + Model.IdAnimalNavigation.IdProprietaireNavigation.Nom
        : "Non défini";
}

<h1>Détails</h1>

<div>
    <h4>Rendez-vous</h4>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">Date</dt>
        <dd class="col-sm-10">@Model.DateRv.ToString("dd/MM/yyyy")</dd>

        <dt class="col-sm-2">Heure</dt>
        <dd class="col-sm-10">@Model.Heure.ToString(@"hh\:mm")</dd>

        <dt class="col-sm-2">Statut</dt>
        <dd class="col-sm-10">@Model.Statut</dd>

        <dt class="col-sm-2">Animal</dt>
        <dd class="col-sm-10">@(Model.IdAnimalNavigation?.Nom ?? "Animal inconnu")</dd>

        <dt class="col-sm-2">Propriétaire</dt>
        <dd class="col-sm-10">@nomProprietaire</dd>

        <dt class="col-sm-2">Vétérinaire</dt>
        <dd class="col-sm-10">@nomVet</dd>
    </dl>
</div>

<div>
    <a asp-action="Edit" asp-route-id="@Model?.IdRendezVous">Modifier</a> |
    <a asp-action="Index">Retour à la liste</a>
</div>