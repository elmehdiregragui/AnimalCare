@model IEnumerable<AnimalCareApplication.Models.RendezVou>

@{
    ViewData["Title"] = "Gestion des Rendez-vous";
    string role = ViewBag.Role as string ?? "";
    string userName = ViewBag.UserName as string ?? "";
}

<div class="lux-container">

    @if (role == "Vétérinaire")
    {
        <div class="alert alert-info mt-3 mb-4 p-4 rounded shadow-sm">
            <h4 class="mb-1">Bienvenue vétérinaire @userName</h4>
            <p class="mb-0">Voici votre liste de rendez-vous.</p>
        </div>
    }

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold">Gestion des Rendez-vous</h2>
        <a asp-action="Create" class="btn btn-success px-4 py-2">
            + Nouveau rendez-vous
        </a>
    </div>

    <div class="table-responsive lux-table">
        <table class="table table-hover align-middle">
            <thead>
                <tr>
                    <th>Date</th>
                    <th>Heure</th>
                    <th>Statut</th>
                    <th>État</th>
                    <th>Animal</th>
                    <th>Propriétaire</th>
                    <th>Vétérinaire</th>
                    <th class="text-center">Actions</th>
                </tr>
            </thead>

            <tbody>
                @foreach (var item in Model)
                {
                    var nomVet = item.IdVeterinaireNavigation?.IdUtilisateurNavigation != null
                    ? System.Globalization.CultureInfo.CurrentCulture.TextInfo.ToTitleCase(
                    (item.IdVeterinaireNavigation.IdUtilisateurNavigation.Prenom + " " +
                    item.IdVeterinaireNavigation.IdUtilisateurNavigation.Nom).ToLower())
                    : "Non défini";

                    var nomProprietaire = item.IdAnimalNavigation?.IdProprietaireNavigation != null
                    ? System.Globalization.CultureInfo.CurrentCulture.TextInfo.ToTitleCase(
                    (item.IdAnimalNavigation.IdProprietaireNavigation.Prenom + " " +
                    item.IdAnimalNavigation.IdProprietaireNavigation.Nom).ToLower())
                    : "Non défini";

                    <tr>
                        <td>@item.DateRv.ToString("dd/MM/yyyy")</td>
                        <td>@item.Heure.ToString(@"hh\:mm")</td>

                        <td>@item.Statut</td>
                        <td>@item.Etat</td>

                        <td>@(item.IdAnimalNavigation?.Nom ?? "Animal inconnu")</td>
                        <td>@nomProprietaire</td>
                        <td>@nomVet</td>

                        <td class="text-center">
                            <a asp-action="Edit" asp-route-id="@item.IdRendezVous" class="btn btn-sm btn-primary">Modifier</a>
                            <a asp-action="Details" asp-route-id="@item.IdRendezVous" class="btn btn-sm btn-info text-white">Détails</a>
                            <a asp-action="Delete" asp-route-id="@item.IdRendezVous" class="btn btn-sm btn-danger">Supprimer</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>