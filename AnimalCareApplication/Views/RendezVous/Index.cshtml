@model IEnumerable<AnimalCareApplication.Models.RendezVou>

@{
    ViewData["Title"] = "Gestion des Rendez-vous";
    string role = ViewBag.Role as string ?? "";
    string userName = ViewBag.UserName as string ?? "";
}

<div class="lux-container">

    @if (role == "Vétérinaire")
    {
        <div class="alert alert-info mt-3 mb-4 p-4 rounded shadow-sm">
            <h4 class="mb-1">Bienvenue vétérinaire @userName</h4>
            <p class="mb-0">Voici votre liste de rendez-vous.</p>
        </div>
    }

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold">Gestion des Rendez-vous</h2>
        <a asp-action="Create" class="btn btn-success px-4 py-2">
            + Nouveau rendez-vous
        </a>
    </div>

    <div class="table-responsive lux-table">
        <table class="table table-hover align-middle">
            <thead>
                <tr>
                    <th>Date</th>
                    <th>Heure</th>
                    <th>Statut</th>
                    <th>Animal (ID)</th>
                    <th>Vétérinaire (ID)</th>
                    <th class="text-center">Actions</th>
                </tr>
            </thead>

            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.DateRv.ToString("dd/MM/yyyy")</td>
                        <td>@item.Heure</td>

                        <td>
                            @if (item.Statut == "Confirmé")
                            {
                                <span class="badge bg-success">Confirmé</span>
                            }
                            else if (item.Statut == "Annulé")
                            {
                                <span class="badge bg-danger">Annulé</span>
                            }
                            else
                            {
                                <span class="badge bg-warning text-dark">En attente</span>
                            }
                        </td>

                        <td>@item.IdAnimalNavigation?.IdAnimal</td>
                        <td>@item.IdVeterinaireNavigation?.IdVeterinaire</td>

                        <td class="text-center">
                            <a asp-action="Edit" asp-route-id="@item.IdRendezVous" class="btn btn-sm btn-primary">Modifier</a>
                            <a asp-action="Details" asp-route-id="@item.IdRendezVous" class="btn btn-sm btn-info text-white">Détails</a>
                            <a asp-action="Delete" asp-route-id="@item.IdRendezVous" class="btn btn-sm btn-danger">Supprimer</a>
                        </td>
                    </tr>
                }
            </tbody>

        </table>
    </div>

</div>
